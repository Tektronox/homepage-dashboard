# Copy this file to .env for local development (never commit .env)

# URL of your local Ollama instance (used for health monitoring)
# Leave empty or omit to disable Ollama monitoring
OLLAMA_URL=http://192.168.0.123:11434

# Virtual Optima service URLs (kept private — not for public repo)
VO_DASHBOARD_URL=https://example.com/
VO_PLANNING_API_URL=https://example.com/health

# Override the HTTP port (default: 3000)
# PORT=3000
